    <Request/>
    <Response/>
  </PreFlow>

  <Flows>

    <Flow name="GetFlow">
      <Condition>request.verb = "GET"</Condition>
    </Flow>

    <Flow name="PostFlow">
      <Condition>request.verb = "POST"</Condition>
    </Flow>

  </Flows>

  <HTTPProxyConnection>
    <BasePath>/test</BasePath>
    <VirtualHost>default</VirtualHost>
  </HTTPProxyConnection>

  <RouteRule name="noroute"/>

</ProxyEndpoint>


