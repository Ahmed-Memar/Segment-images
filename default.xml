test-methods-08-get-wsdl-pass
default.xml



<ProxyEndpoint name="default">
  <Description>apigeelit:allow-method:GET:wsdl</Description>

  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <Condition>(request.verb = "GET") and (request.queryparam.wsdl != null)</Condition>
        <Name>AllowWSDL</Name>
      </Step>

      <Step>
        <Condition>request.verb != "POST"</Condition>
        <Name>RF-InvalidMethod</Name>
      </Step>

      <Step>
        <Name>MV-ValidateXML</Name>
      </Step>
    </Request>
    <Response/>
  </PreFlow>

  <HTTPProxyConnection>
    <BasePath>/test</BasePath>
    <VirtualHost>default</VirtualHost>
  </HTTPProxyConnection>
</ProxyEndpoint>



